{
          "rewrites": [
            { "source": "/admin", "destination": "/admin/login.html" },
            { "source": "/admin/", "destination": "/admin/login.html" }
          ],
          "cleanUrls": true,
          "trailingSlash": false,
          "routes": [
            { "handle": "filesystem" },
            { "src": "/(.*)", "dest": "/404.html", "status": 404 }
          ]
        }